{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/crenexus/diagram_recipe.v1.schema.json",
  "title": "DiagramForge Recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "pages"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "namespace": { "type": "string", "maxLength": 160 },
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "nodes"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string", "minLength": 1, "maxLength": 80 },
          "width": { "type": "integer", "minimum": 320, "maximum": 10000 },
          "height": { "type": "integer", "minimum": 240, "maximum": 10000 },
          "layers": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "object",
              "required": ["key", "name"],
              "properties": { "key": { "type": "string" }, "name": { "type": "string" } },
              "additionalProperties": false
            }
          },
          "nodes": {
            "type": "array",
            "maxItems": 1000,
            "items": {
              "type": "object",
              "required": ["key", "label"],
              "properties": {
                "key": { "type": "string" },
                "label": { "type": "string", "maxLength": 500 },
                "layer": { "type": "string" },
                "role": { "type": "string" },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "width": { "type": "number", "exclusiveMinimum": 0 },
                "height": { "type": "number", "exclusiveMinimum": 0 },
                "style": { "type": "string", "maxLength": 2000 }
              },
              "additionalProperties": false
            }
          },
          "edges": {
            "type": "array",
            "maxItems": 2000,
            "items": {
              "type": "object",
              "required": ["source", "target"],
              "properties": {
                "key": { "type": "string" },
                "source": { "type": "string" },
                "target": { "type": "string" },
                "label": { "type": "string", "maxLength": 240 },
                "layer": { "type": "string" },
                "style": { "type": "string", "maxLength": 2000 }
              },
              "additionalProperties": false
            }
          }
        }
      }
    }
  }
}
